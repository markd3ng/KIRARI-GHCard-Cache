# Browser origins allowed to call this Worker.
# Leave empty to return Access-Control-Allow-Origin: *.
ALLOWED_ORIGINS="https://example.com,https://www.example.com,http://localhost:4321"

# Browser origins allowed to call the Vercel /ghc Function.
# Leave empty to return Access-Control-Allow-Origin: *.
GHC_ALLOWED_ORIGINS="https://example.com,https://www.example.com,http://localhost:4321"

# Public Worker API base used by cron prewarm when rewriting GitHub avatar URLs.
PUBLIC_BASE_URL="https://kirari-ghcard-cache.example.com/api/github"

# Optional cron prewarm targets. Leave empty for no-op.
PREWARM_TARGETS="repo:saicaca/fuwari,content:saicaca/fuwari:README.md,commits:saicaca/fuwari:README.md,avatar:saicaca"

# Do not put real secrets in this file.
# Configure production with:
# pnpm wrangler secret put GITHUB_TOKEN
